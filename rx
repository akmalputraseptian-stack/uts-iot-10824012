//--- Deskripsi ---
// Membaca tombol (field3) dari ThingSpeak,
// jika tombol = 1 maka ambil data suhu & kelembapan (field1 & field2)
// lalu kirim ke MQTT HiveMQ Cloud

#include <WiFi.h>
#include <HTTPClient.h>
#include <WiFiClientSecure.h>
#include <PubSubClient.h>

//--- KONFIGURASI WIFI (Wokwi) ---
const char* ssid = "Wokwi-GUEST";
const char* password = "";

//--- KONFIGURASI MQTT HIVE MQ CLOUD ---
const char* mqtt_server = "de02441951bb44beb2e56c5406f5bc60.s1.eu.hivemq.cloud";
const int   mqtt_port   = 8883;
const char* mqtt_user   = "akmalgani";
const char* mqtt_pass   = "Akmal123";
const char* topic_pub   = "unikom/iot/data";

//--- KONFIGURASI THINGSPEAK ---
// GANTI dengan Channel ID ThingSpeak kamu
String channelID = "ISI_CHANNEL_ID_KAMU";
String readAPI   = "GM0ZNYLC2YOSH4VZ";
String writeAPI  = "GM0ZNYLC2YOSH4VZ";

//--- OBJECT ---
WiFiClientSecure espClient;
PubSubClient client(espClient);

//--- VARIABEL ---
float suhu = 0;
float hum  = 0;

//--- SIMULASI KIRIM KE TX (LoRa) ---
void kirimKeTX(String data) {
  Serial.println("=== Kirim ke TX (LoRa) ===");
  Serial.println(data);
  Serial.println("Status: BERHASIL");
}

//--- FUNGSI KONEKSI WIFI ---
void connectWiFi() {
  Serial.print("Connecting WiFi");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi Connected!");
}

//--- FUNGSI KONEKSI MQTT ---
void connectMQTT() {
  while (!client.connected()) {
    Serial.print("Connecting MQTT Cloud...");
    if (client.connect("esp32_akmal_rx", mqtt_user, mqtt_pass)) {
      Serial.println("Connected!");
    } else {
      Serial.print("Failed, rc=");
      Serial.println(client.state());
      delay(2000);
    }
  }
}

//--- AMBIL DATA SUHU & KELEMBAPAN DARI THINGSPEAK ---
void ambilDataSensor() {
  HTTPClient http;
  String url = "http://api.thingspeak.com/channels/" + channelID +
               "/feeds/last.json?api_key=" + readAPI;
  http.begin(url);
  int httpCode = http.GET();

  if (httpCode == 200) {
    String response = http.getString();
    int sIndex = response.indexOf("\"field1\":\"");
    int hIndex = response.indexOf("\"field2\":\"");

    if (sIndex > 0 && hIndex > 0) {
      suhu = response.substring(sIndex + 10, response.indexOf("\"", sIndex + 10)).toFloat();
      hum  = response.substring(hIndex + 10, response.indexOf("\"", hIndex + 10)).toFloat();
    }

    // Jika data 0 (belum ada sensor), pakai data simulasi
    if (suhu == 0) suhu = random(250, 350) / 10.0;
    if (hum == 0)  hum  = random(600, 900) / 10.0;

    Serial.print("Suhu: ");      Serial.println(suhu);
    Serial.print("Kelembapan: "); Serial.println(hum);
  } else {
    Serial.println("Gagal ambil data sensor, pakai simulasi");
    suhu = random(250, 350) / 10.0;
    hum  = random(600, 900) / 10.0;
  }
  http.end();
}

//--- KIRIM DATA KE MQTT ---
void kirimMQTT() {
  String data = "{";
  data += "\"suhu\":"  + String(suhu) + ",";
  data += "\"hum\":"   + String(hum);
  data += "}";

  client.publish(topic_pub, data.c_str());
  Serial.println("Data dikirim ke MQTT: " + data);
}

//--- RESET TOMBOL DI THINGSPEAK ---
void resetTombol() {
  HTTPClient http;
  String url = "http://api.thingspeak.com/update?api_key=" + writeAPI + "&field3=0";
  http.begin(url);
  http.GET();
  http.end();
  Serial.println("Tombol direset ke 0");
}

//--- BACA STATUS TOMBOL (FIELD 3) ---
void bacaTombol() {
  HTTPClient http;
  String url = "http://api.thingspeak.com/channels/" + channelID +
               "/fields/3/last.txt";
  http.begin(url);
  int httpCode = http.GET();

  if (httpCode == 200) {
    String tombol = http.getString();
    tombol.trim();
    Serial.println("Status tombol: " + tombol);

    if (tombol == "1") {
      Serial.println("Tombol ditekan!");
      ambilDataSensor();
      kirimMQTT();

      String payload = "S=" + String(suhu) + ";H=" + String(hum);
      kirimKeTX(payload);
      resetTombol();
    }
  }
  http.end();
}

//--- SETUP ---
void setup() {
  Serial.begin(115200);
  connectWiFi();
  espClient.setInsecure(); // SSL HiveMQ Cloud
  client.setServer(mqtt_server, mqtt_port);
}

//--- LOOP UTAMA ---
void loop() {
  if (!client.connected()) {
    connectMQTT();
  }
  client.loop();

  static unsigned long lastCheck = 0;
  // Cek tombol tiap 10 detik
  if (millis() - lastCheck > 10000) {
    lastCheck = millis();
    bacaTombol();
  }
}
